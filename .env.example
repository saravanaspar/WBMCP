WHATSAPP_ACCESS_TOKEN=replace-with-your-access-token
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012346
WHATSAPP_GRAPH_API_VERSION=v24.0
# Optional. Omit unless you have a non-empty app secret for future webhook verification.
# WHATSAPP_APP_SECRET=replace-with-your-app-secret
MCP_LOG_LEVEL=info
MCP_ENABLE_DANGEROUS_TOOLS=false

# Local npx MCP clients use stdio. No HTTPS certificate, domain, or port is needed.
MCP_TRANSPORT=stdio

# Optional hosted MCP mode. Uncomment only when intentionally running WBMCP as
# a remote HTTPS Streamable HTTP server.
# MCP_TRANSPORT=https
# MCP_HTTPS_HOST=127.0.0.1
# MCP_HTTPS_PORT=3443
# MCP_HTTPS_PATH=/mcp
# MCP_HTTPS_AUTH_TOKEN=replace-with-at-least-32-random-characters
# MCP_HTTPS_MAX_BODY_BYTES=1048576
# MCP_HTTPS_MAX_SESSIONS=100
# MCP_HTTPS_SESSION_IDLE_TIMEOUT_MS=900000
# MCP_HTTPS_CERT_FILE=/absolute/path/to/cert.pem
# MCP_HTTPS_KEY_FILE=/absolute/path/to/key.pem
